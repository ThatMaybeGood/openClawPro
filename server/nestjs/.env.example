# 筑栖平台 - NestJS 后端环境变量
# ================================
# 复制此文件为 .env 并填写实际值

# ========== 基础配置 ==========
NODE_ENV=development
PORT=3000

# ========== 数据库配置 (PostgreSQL) ==========
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-password-here
DATABASE_NAME=zhiqu_platform

# ========== Redis 配置 (缓存/队列) ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== JWT 认证配置 ==========
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-change-this
JWT_EXPIRATION=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-32-characters-change-this
REFRESH_TOKEN_EXPIRATION=7d

# ========== OAuth2 第三方登录 (可选) ==========
WECHAT_APP_ID=
WECHAT_APP_SECRET=
ALIPAY_APP_ID=
ALIPAY_APP_SECRET=

# ========== 对象存储 OSS (可选) ==========
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=zhiqu-platform

# ========== 邮件服务 SMTP (可选) ==========
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zhiqu.com

# ========== 短信服务 (可选) ==========
SMS_API_KEY=
SMS_API_SECRET=

# ========== 日志配置 ==========
LOG_LEVEL=debug

# ========== 前端域名 (CORS) ==========
FRONTEND_URL=http://localhost:8080

# ========== API 限流配置 ==========
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100

# ========== 文件上传配置 ==========
UPLOAD_MAX_SIZE=10485760  # 10MB
UPLOAD_DIR=./uploads

# ========== 云存储 OSS（可选）==========
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=zhiqu-platform
OSS_REGION=oss-cn-hangzhou
